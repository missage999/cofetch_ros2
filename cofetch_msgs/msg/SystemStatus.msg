# System status
string status          # System status (idle, running, error, maintenance)
float32 cpu_usage       # CPU usage percentage
float32 memory_usage    # Memory usage percentage
float32 network_status  # Network status (0.0-1.0)
int32 active_robots     # Number of active robots
int32 pending_tasks     # Number of pending tasks
string error_message    # Error message if system is in error state